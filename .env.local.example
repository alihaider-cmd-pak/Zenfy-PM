# =====================================================
# ZENFY E-COMMERCE PLATFORM - ENVIRONMENT VARIABLES
# =====================================================
# IMPORTANT: Keep this file PRIVATE - Never commit to git!
# Add to .gitignore: .env.local

# =====================================================
# DATABASE
# =====================================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/zenfy?retryWrites=true&w=majority

# =====================================================
# JWT & AUTHENTICATION
# =====================================================
# Secret key for signing JWT tokens (24-hour expiration)
# IMPORTANT: Change this to a strong random string in production!
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345

# =====================================================
# GMAIL SMTP (Email Notifications)
# =====================================================
# Sender email address
EMAIL_USER=yourgmail@gmail.com

# Gmail App-Specific Password (NOT regular password!)
# To generate:
# 1. Go to: myaccount.google.com/security
# 2. Enable 2-Factor Authentication
# 3. Navigate to: App passwords
# 4. Select: Mail + Windows Computer
# 5. Generate password (16 characters)
EMAIL_PASS=your_16_digit_app_password

# Admin email for receiving order notifications
EMAIL_ADMIN=youradmin@gmail.com

# =====================================================
# SUPPORT CONTACT INFORMATION
# =====================================================
# WhatsApp support number (Pakistani format)
SUPPORT_WHATSAPP=03301958546

# Support email address
SUPPORT_EMAIL=ai.gamer.ff99@gmail.com

# =====================================================
# PAYMENT METHOD CONTACT INFO
# =====================================================
# EasyPaisa mobile account number
EASYPAISA_ACCOUNT=03459708297

# JazzCash mobile account number (can be disabled with JAZZCASH_ENABLED=false)
JAZZCASH_ACCOUNT=disabled

# Enable/disable JazzCash payment method
JAZZCASH_ENABLED=false

# =====================================================
# NEXT.JS CONFIGURATION (PUBLIC - visible in browser)
# =====================================================
# Next.js public environment variables (visible in browser)
# NEXT_PUBLIC_* variables are available in the browser

# Public API URL
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Public support contact information (for PaymentMethods & SupportContact components)
NEXT_PUBLIC_SUPPORT_WHATSAPP=03301958546
NEXT_PUBLIC_SUPPORT_EMAIL=ai.gamer.ff99@gmail.com

# Public payment method account numbers (for PaymentMethods component)
NEXT_PUBLIC_EASYPAISA_ACCOUNT=03459708297
NEXT_PUBLIC_JAZZCASH_ENABLED=false

# =====================================================
# DEVELOPMENT/PRODUCTION
# =====================================================
NODE_ENV=development

# =====================================================
# CORS & SECURITY
# =====================================================
# Allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# API rate limiting (requests per minute)
RATE_LIMIT=100
